<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Focus — Study Dashboard</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Segoe UI', system-ui, sans-serif;
    background: #0f0f13;
    color: #e8e6f0;
    min-height: 100vh;
    padding: 2rem;
  }
  h1 { font-size: 22px; font-weight: 500; color: #e8e6f0; margin-bottom: 4px; }
  .subtitle { font-size: 13px; color: #6b6880; margin-bottom: 2rem; }
  .section-title {
    font-size: 11px; font-weight: 500; color: #6b6880;
    text-transform: uppercase; letter-spacing: 0.06em;
    margin: 2rem 0 0.75rem;
  }
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
  }
  .metric-card {
    background: #1a1825;
    border: 0.5px solid #2e2b3a;
    border-radius: 10px;
    padding: 1rem;
  }
  .metric-label { font-size: 11px; color: #6b6880; margin-bottom: 4px; }
  .metric-value { font-size: 24px; font-weight: 500; color: #e8e6f0; }
  .metric-sub { font-size: 11px; color: #4e4b5e; margin-top: 2px; }
  .chart-wrap { position: relative; width: 100%; }
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 2rem; }
  .legend-row { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 10px; }
  .legend-item { display: flex; align-items: center; gap: 5px; font-size: 12px; color: #9390a8; }
  .legend-dot { width: 10px; height: 10px; border-radius: 2px; flex-shrink: 0; }
  @media (max-width: 600px) {
    .metrics-grid { grid-template-columns: repeat(2, 1fr); }
    .two-col { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<h1>Focus — Dashboard de Estudos</h1>
<p class="subtitle">Fuvest 2027 · Jan–Mar 2026</p>

<div class="metrics-grid">
  <div class="metric-card">
    <p class="metric-label">Total estudado</p>
    <p class="metric-value" id="total-hours">—</p>
    <p class="metric-sub">horas</p>
  </div>
  <div class="metric-card">
    <p class="metric-label">Sessões</p>
    <p class="metric-value" id="total-sessions">—</p>
    <p class="metric-sub">registros</p>
  </div>
  <div class="metric-card">
    <p class="metric-label">Questões corretas</p>
    <p class="metric-value" id="total-correct">—</p>
    <p class="metric-sub" id="accuracy-pct">—</p>
  </div>
  <div class="metric-card">
    <p class="metric-label">Matéria mais estudada</p>
    <p class="metric-value" id="top-subject" style="font-size:16px;">—</p>
    <p class="metric-sub" id="top-subject-hours">—</p>
  </div>
</div>

<p class="section-title">Horas por matéria</p>
<div class="legend-row" id="subject-legend"></div>
<div class="chart-wrap" style="height:220px;">
  <canvas id="subjectChart"></canvas>
</div>

<div class="two-col">
  <div>
    <p class="section-title" style="margin-top:0;">Horas por semana</p>
    <div class="chart-wrap" style="height:200px;">
      <canvas id="weekChart"></canvas>
    </div>
  </div>
  <div>
    <p class="section-title" style="margin-top:0;">Taxa de acerto por matéria</p>
    <div class="chart-wrap" style="height:200px;">
      <canvas id="accuracyChart"></canvas>
    </div>
  </div>
</div>

<p class="section-title">Progresso diário (jan–mar 2026)</p>
<div class="chart-wrap" style="height:180px;">
  <canvas id="timelineChart"></canvas>
</div>

<script>
const logs = [
  {date:"2026-01-31",subject:"Outro",duration:3060},
  {date:"2026-01-31",subject:"Matemática",duration:9151},
  {date:"2026-02-02",subject:"Matemática",duration:6972},
  {date:"2026-02-03",subject:"Outro",duration:882},
  {date:"2026-02-03",subject:"Português",duration:3944},
  {date:"2026-02-04",subject:"Matemática",duration:8839},
  {date:"2026-02-05",subject:"Química",duration:5402},
  {date:"2026-02-06",subject:"Outro",duration:1886},
  {date:"2026-02-06",subject:"Redação",duration:4316},
  {date:"2026-02-08",subject:"Matemática",duration:8486},
  {date:"2026-02-09",subject:"Matemática",duration:3239},
  {date:"2026-02-11",subject:"Outro",duration:1871},
  {date:"2026-02-13",subject:"Química",duration:6988},
  {date:"2026-02-16",subject:"Matemática",duration:4125},
  {date:"2026-02-16",subject:"Matemática",duration:3457},
  {date:"2026-02-17",subject:"Matemática",duration:8701},
  {date:"2026-02-18",subject:"Redação",duration:10830},
  {date:"2026-02-20",subject:"Física",duration:5289},
  {date:"2026-02-23",subject:"Matemática",duration:6913},
  {date:"2026-02-23",subject:"Biologia",duration:3465},
  {date:"2026-02-27",subject:"Redação",duration:7570},
  {date:"2026-02-27",subject:"Matemática",duration:4365},
  {date:"2026-03-05",subject:"Matemática",duration:4457},
  {date:"2026-03-06",subject:"Matemática",duration:1669},
  {date:"2026-03-06",subject:"Matemática",duration:4477},
  {date:"2026-03-08",subject:"Matemática",duration:7298},
  {date:"2026-03-09",subject:"Química",duration:6225},
  {date:"2026-03-10",subject:"Geografia",duration:6823},
  {date:"2026-03-12",subject:"Matemática",duration:6542},
  {date:"2026-03-13",subject:"História",duration:6553},
  {date:"2026-03-13",subject:"História",duration:2073},
  {date:"2026-03-14",subject:"Português",duration:4901},
  {date:"2026-03-14",subject:"Matemática",duration:6320},
  {date:"2026-03-15",subject:"Física",duration:4391},
  {date:"2026-03-16",subject:"Química",duration:1671},
  {date:"2026-03-17",subject:"Química",duration:3177},
  {date:"2026-03-17",subject:"Matemática",duration:4475},
  {date:"2026-03-17",subject:"Matemática",duration:1480},
  {date:"2026-03-19",subject:"Matemática",duration:5934},
  {date:"2026-03-19",subject:"Física",duration:4398},
  {date:"2026-03-20",subject:"Química",duration:6542},
  {date:"2026-03-20",subject:"Matemática",duration:3488},
  {date:"2026-03-22",subject:"Geografia",duration:4272},
  {date:"2026-03-22",subject:"Física",duration:1652},
  {date:"2026-03-23",subject:"Matemática",duration:7552},
  {date:"2026-03-23",subject:"Matemática",duration:1922},
  {date:"2026-03-25",subject:"História",duration:6140},
  {date:"2026-03-25",subject:"Matemática",duration:3921},
  {date:"2026-03-27",subject:"Matemática",duration:3723},
  {date:"2026-03-28",subject:"Matemática",duration:9255},
  {date:"2026-03-28",subject:"Biologia",duration:2115},
  {date:"2026-03-31",subject:"Matemática",duration:3321},
  {date:"2026-03-31",subject:"Matemática",duration:5424},
  {date:"2026-03-31",subject:"Biologia",duration:3155},
];

const questions = {
  "Matemática":{correct:272,incorrect:91},
  "Química":{correct:37,incorrect:12},
  "Física":{correct:21,incorrect:7},
  "História":{correct:15,incorrect:21},
  "Biologia":{correct:14,incorrect:0},
};

const colors = {
  "Matemática":"#6366f1","Redação":"#94a3b8","Química":"#f97316",
  "Física":"#a3e635","Biologia":"#a78bfa","História":"#38bdf8",
  "Geografia":"#34d399","Português":"#34d399","Outro":"#f43f5e"
};

const gridColor = 'rgba(255,255,255,0.06)';
const tickColor = '#6b6880';

const bySubject = {};
logs.forEach(l => { bySubject[l.subject] = (bySubject[l.subject]||0) + l.duration; });
const totalSecs = Object.values(bySubject).reduce((a,b)=>a+b,0);
document.getElementById('total-hours').textContent = (totalSecs/3600).toFixed(1);
document.getElementById('total-sessions').textContent = logs.length;

let totalC=0,totalI=0;
Object.values(questions).forEach(q=>{totalC+=q.correct;totalI+=q.incorrect;});
const acc = Math.round(totalC/(totalC+totalI)*100);
document.getElementById('total-correct').textContent = totalC;
document.getElementById('accuracy-pct').textContent = acc + '% de acerto';

const topS = Object.entries(bySubject).sort((a,b)=>b[1]-a[1])[0];
document.getElementById('top-subject').textContent = topS[0];
document.getElementById('top-subject-hours').textContent = (topS[1]/3600).toFixed(1) + 'h registradas';

const subjEntries = Object.entries(bySubject).sort((a,b)=>b[1]-a[1]);
const subjLabels = subjEntries.map(e=>e[0]);
const subjHours = subjEntries.map(e=>+(e[1]/3600).toFixed(2));
const subjColors = subjLabels.map(s=>colors[s]||'#888');

const legendEl = document.getElementById('subject-legend');
subjLabels.forEach((s,i)=>{
  legendEl.innerHTML += `<span class="legend-item"><span class="legend-dot" style="background:${subjColors[i]}"></span>${s} ${subjHours[i].toFixed(1)}h</span>`;
});

new Chart(document.getElementById('subjectChart'),{
  type:'bar',
  data:{labels:subjLabels,datasets:[{data:subjHours,backgroundColor:subjColors,borderRadius:5}]},
  options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{
    x:{ticks:{color:tickColor,font:{size:11}},grid:{display:false},border:{color:'transparent'}},
    y:{ticks:{color:tickColor,font:{size:11},callback:v=>v+'h'},grid:{color:gridColor},border:{color:'transparent'}}
  }}
});

const weekMap = {};
logs.forEach(l=>{
  const d = new Date(l.date);
  const jan1 = new Date(d.getFullYear(),0,1);
  const week = Math.ceil(((d-jan1)/86400000+jan1.getDay()+1)/7);
  const key = `W${String(week).padStart(2,'0')}`;
  weekMap[key] = (weekMap[key]||0)+l.duration;
});
const weekKeys = Object.keys(weekMap).sort();
const weekHours = weekKeys.map(k=>+(weekMap[k]/3600).toFixed(2));

new Chart(document.getElementById('weekChart'),{
  type:'line',
  data:{labels:weekKeys,datasets:[{data:weekHours,borderColor:'#6366f1',backgroundColor:'rgba(99,102,241,0.1)',fill:true,tension:0.4,pointRadius:3,pointBackgroundColor:'#6366f1'}]},
  options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{
    x:{ticks:{color:tickColor,font:{size:10},maxRotation:45,autoSkip:false},grid:{display:false},border:{color:'transparent'}},
    y:{ticks:{color:tickColor,font:{size:10},callback:v=>v+'h'},grid:{color:gridColor},border:{color:'transparent'}}
  }}
});

const accSubjects = Object.entries(questions).filter(([,q])=>q.correct+q.incorrect>0);
new Chart(document.getElementById('accuracyChart'),{
  type:'bar',
  data:{labels:accSubjects.map(([s])=>s),datasets:[{data:accSubjects.map(([,q])=>Math.round(q.correct/(q.correct+q.incorrect)*100)),backgroundColor:accSubjects.map(([s])=>colors[s]||'#888'),borderRadius:5}]},
  options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{
    x:{ticks:{color:tickColor,font:{size:11}},grid:{display:false},border:{color:'transparent'}},
    y:{min:0,max:100,ticks:{color:tickColor,font:{size:11},callback:v=>v+'%'},grid:{color:gridColor},border:{color:'transparent'}}
  }}
});

const dayMap = {};
logs.forEach(l=>{dayMap[l.date]=(dayMap[l.date]||0)+l.duration;});
const dayKeys = Object.keys(dayMap).sort();
new Chart(document.getElementById('timelineChart'),{
  type:'bar',
  data:{labels:dayKeys.map(d=>d.slice(5)),datasets:[{data:dayKeys.map(k=>+(dayMap[k]/3600).toFixed(2)),backgroundColor:'#6366f1',borderRadius:3}]},
  options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{
    x:{ticks:{color:tickColor,font:{size:10},maxRotation:45,autoSkip:true},grid:{display:false},border:{color:'transparent'}},
    y:{ticks:{color:tickColor,font:{size:10},callback:v=>v+'h'},grid:{color:gridColor},border:{color:'transparent'}}
  }}
});
</script>
</body>
</html>
